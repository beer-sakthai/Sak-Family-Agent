SAKTHAI_FAST=1
# Per-agent memory root — do NOT point this at a path shared with any other
# persona (sakking/sakthai/saksee/saksit/saktan/sakjules); doing so silently
# merges their memory/cycle-stage state. Matches sakthai-agent-run.sh's
# $HOME/.sakthai/$AGENT convention.
SAKTHAI_HOME=/home/beerthai/.sakthai/saksee
SAKTHAI_MODEL=gpt-5.4-mini
SAKTHAI_SYSTEM_PROMPT_FILE=/home/beerthai/Sak-Family-Agent/personas/saksee/SOUL.md
SAKTHAI_WITH_SKILLS=playwright
TELEGRAM_ALLOWED_USER_IDS=123456789
TELEGRAM_BOT_TOKEN=replace-me
