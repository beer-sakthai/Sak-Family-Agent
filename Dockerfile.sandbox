# Isolated execution environment for `sakthai run --sandbox`.
# run_command executes here — no host filesystem is mounted except memory.db.
#
# checkov:skip=CKV_DOCKER_2: Ephemeral task container, not a service — HEALTHCHECK is meaningless here
# checkov:skip=CKV_DOCKER_3: Runs as root so the bind-mounted memory.db keeps host-writable ownership
FROM python:3.11-slim

# Common CLI tools that run_command is likely to need
RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl wget jq unzip bash make \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install sakthai (core only — no dashboard/e2e extras). The package sources
# live under personas/sakthai/sakthai (see [tool.setuptools.packages.find] in
# pyproject.toml), so mirror that layout inside the image.
COPY pyproject.toml README.md ./
COPY personas/sakthai/sakthai/ ./personas/sakthai/sakthai/
COPY library/ ./library/

RUN pip install --no-cache-dir -e "."

# Memory store mount point; host binds memory.db here at runtime
RUN mkdir -p /root/.sakthai

# Shell execution is safe inside the container — that is the whole point
ENV SAKTHAI_SHELL_ALLOW=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

ENTRYPOINT ["sakthai"]
